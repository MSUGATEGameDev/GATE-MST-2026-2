    - target: {fileID: 1643042681783036059, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'm_Materials.Array.data[0]'
      value: 
      objectReference: {fileID: 2100000, guid: 6a9946fd8eb87b54d9479a0962aced83, type: 2}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: npcName
      value: John Tutorial
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: singleActivation
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: dialog.Array.size
      value: 7
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[0]'
      value: Oh.... you survived.
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[1]'
      value: I'm sorry that I tried to kill you.
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[2]'
      value: 'I was so blinded by my money that I didn''t realize I was hurting innocent
        people. '
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[3]'
      value: 'But when I saw you fighting those enemies with that hopeful spark in
        your eye... I snapped out of it. '
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[4]'
      value: 'I''m going to sell my companies and donate all my money to charity
        now. '
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[5]'
      value: 'Maybe then Jane will love me again.... '
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[6]'
      value: 'Thank you for opening my eyes. '
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: 'dialog.Array.data[7]'
      value: (say hi to my wife for me ok?)
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
      propertyPath: objectsToActivate.Array.size
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 1708576647234818529, guid: 6bcbd75a4bd4dba45802087238127d31, type: 3}
